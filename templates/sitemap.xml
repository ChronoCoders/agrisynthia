{% load i18n %}<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xhtml="http://www.w3.org/1999/xhtml">
{% get_available_languages as LANGUAGES %}{% with site='https://agrisynthia.com' %}
{% for route in routes %}{% for lang_code, lang_name in LANGUAGES %}  <url>
    {% language lang_code %}<loc>{{ site }}{% url route.name %}</loc>{% endlanguage %}
{% for alt_code, alt_name in LANGUAGES %}    {% language alt_code %}<xhtml:link rel="alternate" hreflang="{{ alt_code }}" href="{{ site }}{% url route.name %}" />{% endlanguage %}
{% endfor %}    {% language 'tr' %}<xhtml:link rel="alternate" hreflang="x-default" href="{{ site }}{% url route.name %}" />{% endlanguage %}
    <changefreq>{{ route.changefreq }}</changefreq>
    <priority>{{ route.priority }}</priority>
  </url>
{% endfor %}{% endfor %}{% for slug in blog_slugs %}{% for lang_code, lang_name in LANGUAGES %}  <url>
    {% language lang_code %}<loc>{{ site }}{% url 'website:blog_detail' slug=slug %}</loc>{% endlanguage %}
{% for alt_code, alt_name in LANGUAGES %}    {% language alt_code %}<xhtml:link rel="alternate" hreflang="{{ alt_code }}" href="{{ site }}{% url 'website:blog_detail' slug=slug %}" />{% endlanguage %}
{% endfor %}    {% language 'tr' %}<xhtml:link rel="alternate" hreflang="x-default" href="{{ site }}{% url 'website:blog_detail' slug=slug %}" />{% endlanguage %}
    <changefreq>yearly</changefreq>
    <priority>0.7</priority>
  </url>
{% endfor %}{% endfor %}{% endwith %}</urlset>
