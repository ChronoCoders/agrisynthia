# Required in production
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DJANGO_ENVIRONMENT=production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Database
DATABASE_NAME=agrisynthia
DATABASE_USER=agrisynthia_user
DATABASE_PASSWORD=change-this-strong-password
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
REDIS_PASSWORD=change-this-redis-password


# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Alert Configuration
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
ALERT_EMAIL_RECIPIENTS=admin@your-domain.com,team@your-domain.com
ALERT_COOLDOWN_SECONDS=3600

# Email (SMTP — only required in production)
# Gmail SMTP works but caps at 500/day. For real transactional volume use
# AWS SES, Postmark, SendGrid, Mailgun, or Resend — just point EMAIL_HOST at them.
DEFAULT_FROM_EMAIL=Agrisynthia <noreply@your-domain.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_TIMEOUT=10

# CSRF trusted origins (comma-separated, full URLs with scheme — Django 4+ requires this for HTTPS POSTs)
# Defaults to https://<host> for every entry in DJANGO_ALLOWED_HOSTS if left blank.
CSRF_TRUSTED_ORIGINS=

# NodeODM Integration (set ODM_ENABLED=False to use pre-processed orthophotos)
ODM_ENABLED=True
ODM_HOST=localhost
ODM_PORT=3000
ODM_TOKEN=
ODM_STUCK_TIMEOUT_MINUTES=120

# Sentinel-2 NDVI (Element84 Earth Search, no credentials required)
SENTINEL2_CLOUD_MAX=30

# NDVI stress alert thresholds (used by weekly Beat task)
NDVI_STRESS_THRESHOLD=0.3
NDVI_WARN_THRESHOLD=0.5
NDVI_ALERT_COOLDOWN_DAYS=7

# Sentry error tracking (leave blank to disable)
SENTRY_DSN=

# GeoDjango / PostGIS — set to False on Windows without OSGeo4W to use JSON fallback.
# Production (Linux+PostGIS): GEODJANGO_ENABLED=True
# Windows dev without GDAL: GEODJANGO_ENABLED=False
GEODJANGO_ENABLED=True

# GeoDjango — Windows only. Leave blank on Linux/Docker (system GDAL is auto-detected).
# Install GDAL via OSGeo4W: https://trac.osgeo.org/osgeo4w/
# Example: GDAL_LIBRARY_PATH=C:\OSGeo4W\bin\gdal310.dll
GDAL_LIBRARY_PATH=
GEOS_LIBRARY_PATH=

# Grafana admin password (required when running monitoring stack)
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password

# Cloudflare R2 object storage (set USE_R2=True to enable; False uses local media/)
USE_R2=False
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
# Optional: custom domain / public hostname for the bucket (leave blank to use R2 endpoint)
R2_CUSTOM_DOMAIN=
